PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://127.0.0.1:5501
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hudheele_pos
JWT_ACCESS_SECRET=replace_with_long_access_secret
JWT_REFRESH_SECRET=replace_with_long_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
DEFAULT_TENANT_ID=1
DEFAULT_BRANCH_ID=1
BUSINESS_TIMEZONE=Africa/Hargeisa
CLOUD_DATABASE_URL=postgresql://postgres:postgres@cloud-host:5432/hudheele_pos_cloud
SYNC_INTERVAL_HOURS=24
SYNC_BATCH_SIZE=500
